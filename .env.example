# Copie para .env.local e preencha. NUNCA commitar segredos (CLAUDE.md §10).
# Em produção, as variáveis vivem na Vercel (Settings → Environment Variables).

# Site (canônico de produção)
NEXT_PUBLIC_SITE_URL=https://salesclub.com.br

# Sanity (CMS) — projectId/dataset são públicos (expostos ao client/Studio)
NEXT_PUBLIC_SANITY_PROJECT_ID=3vneeegd
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Token só é necessário se o dataset for privado (leitura) ou para escrever.
SANITY_API_TOKEN=

# Pipedrive (CRM) — destino dos leads. Sem token => modo mock (dev).
# Token do usuário "site" (Configurações > Pessoal > API na conta salesclub2).
PIPEDRIVE_API_TOKEN=
# Base = domínio da empresa no Pipedrive (integração usa API v2 + v1 p/ fields/search/notes)
PIPEDRIVE_BASE_URL=https://salesclub2.pipedrive.com
# PIPEDRIVE_DRY_RUN=1 => resolve os payloads e responde sem criar nada (validação)
PIPEDRIVE_DRY_RUN=
# Funis por origem (opcional; sem valor => funil padrão)
PIPEDRIVE_PIPELINE_IMERSOES=
PIPEDRIVE_PIPELINE_SERVICOS=
PIPEDRIVE_PIPELINE_CORPORATE=
PIPEDRIVE_PIPELINE_ELITE=
PIPEDRIVE_PIPELINE_VILLAGE=
PIPEDRIVE_PIPELINE_EVENTOS=
PIPEDRIVE_PIPELINE_UNIVERSIDADE=
PIPEDRIVE_PIPELINE_DIAGNOSTICO=
PIPEDRIVE_PIPELINE_MATERIAIS=

# Backup de leads em planilha Google (Apps Script Web App, URL /exec).
# Sem valor => backup desativado (no-op). Ver docs/HANDOVER.md §Leads.
SHEETS_WEBHOOK_URL=

# Newsletter (ESP — RD Station / Mailchimp / etc.). Mockado até definir.
NEWSLETTER_API_TOKEN=

# Anti-spam (Cloudflare Turnstile) — ainda não ativado
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Analytics — GTM e Meta Pixel têm fallback hardcoded em lib/analytics.ts;
# GA4 fica inerte sem o ID (G-XXXXXXXXXX).
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA4_ID=
